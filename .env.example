# ==========================================================================
# Lanny Santana Nutricionista — Variáveis de Ambiente
# Copie este arquivo para ".env.local" e preencha os valores reais.
# ==========================================================================

# ---- App -----------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Lanny Santana Nutricionista"

# ---- Supabase (banco de dados + auth do admin) ----------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Pagamentos (Mercado Pago Checkout Pro) ---------------------------------
# Access Token de PRODUÇÃO da sua conta Mercado Pago (nunca o de teste em
# produção). Server-only — nunca leve isso para o navegador.
# Painel: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=

# ---- Agenda -------------------------------------------------------------------
# "supabase" (padrão — usa business_hours/blocked_dates, editável em
# /admin/configuracoes) | "mock" (dados de exemplo, sem Supabase) | "google" | "calendly"
NEXT_PUBLIC_CALENDAR_PROVIDER=supabase

# ---- Google Calendar --------------------------------------------------------
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=

# ---- Calendly (alternativa ao Google Calendar) ------------------------------
CALENDLY_API_KEY=
CALENDLY_EVENT_TYPE_URI=

# ---- WhatsApp Business API --------------------------------------------------
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_NUMBER=5500000000000

# ---- Resend (e-mails transacionais) -----------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL="Lanny Santana Nutricionista <contato@lannysantana.com.br>"

# ---- OpenAI (Assistente Lanny - chatbot) ------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Admin -------------------------------------------------------------------
ADMIN_EMAIL=admin@lannysantana.com.br
